{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "include": [
    "caffeine-build/cmake/presets/base.json",
    "caffeine-build/cmake/presets/stm32/stm32f4.json",
    "caffeine-build/cmake/presets/posix/linux.json",
    "caffeine-build/cmake/presets/mock/tests.json"
  ],
  "configurePresets": [
    {
      "name": "blinky-board-ex1",
      "displayName": "Blinky Example 1 (STM32F407)",
      "inherits": "stm32f407-release",
      "cacheVariables": {
        "CAFFEINE_APP_MVP_BLINKY_BOARD_EX1": "ON"
      }
    },
    {
      "name": "blinky-board-ex2",
      "displayName": "Blinky Example 2 (STM32F417VG)",
      "inherits": "stm32f417vg-release",
      "cacheVariables": {
        "CAFFEINE_APP_MVP_BLINKY_BOARD_EX2": "ON"
      }
    }
  ]
}